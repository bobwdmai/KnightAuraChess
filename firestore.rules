rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isBotProfile(uid, data) {
      return data.isBot == true &&
        data.uid == uid &&
        uid.matches('bot_.*');
    }

    function isValidHumanDisplayName(displayName) {
      return displayName is string &&
        displayName == displayName.trim() &&
        displayName.size() > 0 &&
        displayName.size() <= 40 &&
        !displayName.matches('.*\\/.*');
    }

    function hasValidHumanUsernameFields(data, uid) {
      return data.uid == uid &&
        isValidHumanDisplayName(data.displayName) &&
        data.usernameKey is string &&
        data.usernameKey == data.displayName.lower();
    }

    function matchingUsernameClaimAfter(uid) {
      return hasValidHumanUsernameFields(request.resource.data, uid) &&
        existsAfter(/databases/$(database)/documents/usernames/$(request.resource.data.usernameKey)) &&
        getAfter(/databases/$(database)/documents/usernames/$(request.resource.data.usernameKey)).data.uid == uid &&
        getAfter(/databases/$(database)/documents/usernames/$(request.resource.data.usernameKey)).data.displayName == request.resource.data.displayName;
    }

    function usernameFieldsChanged() {
      return request.resource.data.displayName != resource.data.displayName ||
        request.resource.data.usernameKey != resource.data.usernameKey;
    }

    function isMatchStatUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'rating',
        'wins',
        'losses',
        'draws',
        'updatedAt'
      ]);
    }

    function isGameParticipant(gameId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/games/$(gameId)) &&
        (
          get(/databases/$(database)/documents/games/$(gameId)).data.whiteId == request.auth.uid ||
          get(/databases/$(database)/documents/games/$(gameId)).data.blackId == request.auth.uid
        );
    }

    function isMoveStateUpdate() {
      return request.resource.data.fen != resource.data.fen;
    }

    function hasValidMoveSeqTransition() {
      return request.resource.data.moveSeq is int &&
        request.resource.data.lastMove is map &&
        request.resource.data.lastMove.seq is int &&
        request.resource.data.lastMove.seq == request.resource.data.moveSeq &&
        (
          (resource.data.moveSeq is int && request.resource.data.moveSeq == resource.data.moveSeq + 1) ||
          (!(resource.data.moveSeq is int) && request.resource.data.moveSeq == 1)
        );
    }

    function isValidUsernameClaim(usernameKey, data) {
      return data.keys().hasOnly([
          'uid',
          'displayName',
          'createdAt',
          'updatedAt'
        ]) &&
        data.uid == request.auth.uid &&
        isValidHumanDisplayName(data.displayName) &&
        usernameKey == data.displayName.lower();
    }

    function isValidDmParticipants(data) {
      return data.participants is list &&
        data.participants.size() == 2 &&
        data.participants[0] is string &&
        data.participants[1] is string;
    }

    function isDmParticipant(data) {
      return isSignedIn() &&
        isValidDmParticipants(data) &&
        data.participants.hasAny([request.auth.uid]);
    }

    function isPuzzleModerator() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.puzzleModerator == true
      );
    }

    function isValidPuzzleFollow(creatorId, followerId, data) {
      return data.creatorId == creatorId &&
        data.followerId == followerId &&
        data.creatorName is string &&
        data.creatorName.size() > 0 &&
        data.creatorName.size() <= 80 &&
        data.followerName is string &&
        data.followerName.size() > 0 &&
        data.followerName.size() <= 80 &&
        data.followerEmail is string &&
        data.followerEmail.size() > 3 &&
        data.followerEmail.size() <= 160;
    }

    function isValidPuzzleRating(uid, data) {
      return data.uid == uid &&
        data.rating is int &&
        data.rating >= 1 &&
        data.rating <= 5;
    }

    function isValidPuzzleEmail(data) {
      return data.creatorId == request.auth.uid &&
        data.followerId is string &&
        data.puzzleId is string &&
        data.to is string &&
        exists(/databases/$(database)/documents/puzzle_creators/$(data.creatorId)/followers/$(data.followerId)) &&
        get(/databases/$(database)/documents/puzzle_creators/$(data.creatorId)/followers/$(data.followerId)).data.followerEmail == data.to &&
        data.template is map &&
        data.template.name == 'newCommunityPuzzle' &&
        data.template.data is map &&
        data.template.data.authorName is string &&
        data.template.data.puzzleTitle is string &&
        data.template.data.puzzleUrl is string;
    }

    function isValidCommunityPuzzle(data) {
      return data.title is string &&
        data.title.size() > 0 &&
        data.title.size() <= 80 &&
        data.description is string &&
        data.description.size() <= 240 &&
        data.fen is string &&
        data.fen.size() > 0 &&
        data.fen.size() <= 120 &&
        data.solution is string &&
        data.solution.size() > 0 &&
        data.solution.size() <= 32 &&
        (!('solutionMoves' in data) || (
          data.solutionMoves is list &&
          data.solutionMoves.size() > 0 &&
          data.solutionMoves.size() <= 20
        )) &&
        data.authorId is string &&
        data.authorName is string &&
        data.authorName.size() > 0 &&
        data.authorName.size() <= 80 &&
        (!('hint' in data) || (data.hint is string && data.hint.size() <= 120)) &&
        (!('tags' in data) || (data.tags is list && data.tags.size() <= 5)) &&
        (!('featured' in data) || data.featured is bool) &&
        (!('status' in data) || data.status in ['pending', 'approved', 'rejected']);
    }

    function isCreatorPuzzleUpdate() {
      return resource.data.authorId == request.auth.uid &&
        request.resource.data.authorId == resource.data.authorId &&
        isValidCommunityPuzzle(request.resource.data) &&
        (
          ('featured' in resource.data && request.resource.data.featured == resource.data.featured) ||
          (
            !('featured' in resource.data) &&
            (
              !('featured' in request.resource.data) ||
              request.resource.data.featured == false
            )
          )
        ) &&
        request.resource.data.status == 'pending';
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        isBotProfile(uid, request.resource.data) ||
        (isSelf(uid) && matchingUsernameClaimAfter(uid))
      );
      allow update: if isSignedIn() && (
        isBotProfile(uid, request.resource.data) ||
        (
          isSelf(uid) &&
          hasValidHumanUsernameFields(request.resource.data, uid) &&
          (!usernameFieldsChanged() || matchingUsernameClaimAfter(uid))
        ) ||
        isMatchStatUpdate()
      );

      match /puzzle_following/{creatorId} {
        allow read, delete: if isSelf(uid);
        allow create, update: if isSelf(uid) &&
          isValidPuzzleFollow(creatorId, uid, request.resource.data);
      }
    }

    match /usernames/{usernameKey} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() &&
        !exists(/databases/$(database)/documents/usernames/$(usernameKey)) &&
        isValidUsernameClaim(usernameKey, request.resource.data);
      allow update: if isSignedIn() &&
        resource.data.uid == request.auth.uid &&
        isValidUsernameClaim(usernameKey, request.resource.data);
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /games/{gameId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.whiteId == request.auth.uid;
      allow update: if isGameParticipant(gameId) &&
        (!isMoveStateUpdate() || hasValidMoveSeqTransition());
      allow delete: if isGameParticipant(gameId);

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 200;
      }

      match /voice/{voiceDocId} {
        allow read, write: if isGameParticipant(gameId);
      }

      match /voiceSessions/{sessionId} {
        allow read, write: if isGameParticipant(gameId);

        match /{candidateCollection}/{candidateId} {
          allow read, write: if isGameParticipant(gameId);
        }
      }
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow create: if isSignedIn() && (
        request.resource.data.authorId == request.auth.uid ||
        (
          request.resource.data.authorId is string &&
          request.resource.data.authorId.matches('^bot_.*')
        )
      );
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    match /community_puzzles/{puzzleId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.authorId == request.auth.uid &&
        isValidCommunityPuzzle(request.resource.data) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.featured == false;
      allow update: if (isPuzzleModerator() && isValidCommunityPuzzle(request.resource.data)) ||
        isCreatorPuzzleUpdate();
      allow delete: if isPuzzleModerator() ||
        (isSignedIn() && resource.data.authorId == request.auth.uid);

      match /ratings/{uid} {
        allow read: if true;
        allow create, update: if isSignedIn() &&
          request.auth.uid == uid &&
          isValidPuzzleRating(uid, request.resource.data);
        allow delete: if isSignedIn() && request.auth.uid == uid;
      }
    }

    match /puzzle_creators/{creatorId}/followers/{followerId} {
      allow read: if isSignedIn() && (
        request.auth.uid == creatorId ||
        request.auth.uid == followerId
      );
      allow create, update: if isSignedIn() &&
        request.auth.uid == followerId &&
        isValidPuzzleFollow(creatorId, followerId, request.resource.data);
      allow delete: if isSignedIn() && request.auth.uid == followerId;
    }

    match /mail/{mailId} {
      allow create: if isSignedIn() &&
        isValidPuzzleEmail(request.resource.data);
      allow read, update, delete: if false;
    }

    match /dms/{chatId} {
      allow read: if isDmParticipant(resource.data);
      allow create: if isDmParticipant(request.resource.data);
      allow update: if isDmParticipant(resource.data) &&
        request.resource.data.participants == resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isDmParticipant(get(/databases/$(database)/documents/dms/$(chatId)).data);
        allow create: if isDmParticipant(get(/databases/$(database)/documents/dms/$(chatId)).data) &&
          request.resource.data.senderId == request.auth.uid;
      }
    }

    match /friend_requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.from == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.from == request.auth.uid ||
        resource.data.to == request.auth.uid
      );
      // Allow delete for declining/removing friends
      allow delete: if isSignedIn() && (
        resource.data.from == request.auth.uid ||
        resource.data.to == request.auth.uid
      );
    }

    match /game_challenges/{challengeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.resource.data.from == request.auth.uid ||
        (
          request.resource.data.from is string &&
          request.resource.data.from.matches('^bot_') &&
          request.resource.data.to == request.auth.uid
        )
      );
      allow update: if isSignedIn() && resource.data.to == request.auth.uid;
      allow delete: if isSignedIn() && (
        resource.data.from == request.auth.uid ||
        resource.data.to == request.auth.uid
      );
    }
  }
}
