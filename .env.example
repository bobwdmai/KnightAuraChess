# Firebase client config (do not commit real keys)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# AI endpoint (backend URL)
VITE_AI_ENDPOINT=http://localhost:8000
VITE_AI_DIFFICULTY=expert
# Optional tuning
# VITE_AI_DEPTH=6
# VITE_AI_TIME=2.0

# Optional: base path for static hosting (e.g. /your-repo-name/)
# VITE_BASE_PATH=/ChessRider/

# Optional: local dev proxy target for /ai routes
# VITE_DEV_AI_PROXY_TARGET=http://localhost:8000

# Talking AI for bot DMs
# In cloud deployment, use the same-origin proxy endpoint below and point it at a hosted LLM.
VITE_TEXT_AI_BASE_URL=/api/text-ai
VITE_TEXT_AI_MODEL=smollm:135m

# Cloudflare Workers AI for /api/text-ai
# Add an AI binding named AI in Cloudflare Pages/Workers.
# Optional: override the model used by the Worker AI binding.
TEXT_AI_MODEL=@cf/meta/llama-3-8b-instruct

# Optional fallback if you prefer to proxy to another hosted LLM instead of Workers AI.
# TEXT_AI_UPSTREAM_URL=https://your-llm-endpoint.example/v1/chat/completions
# TEXT_AI_UPSTREAM_AUTH_BEARER=optional_api_key_or_token
