# Firebase client config (do not commit real keys)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional frontend settings
VITE_AI_DIFFICULTY=medium
# VITE_BASE_PATH=/
VITE_TEXT_AI_BASE_URL=/api/text-ai
# VITE_TEXT_AI_MODEL=deepseek/deepseek-r1-0528-qwen3-8b
VITE_MOVE_API_ENABLED=true
VITE_MOVE_API_STRICT=true
VITE_MOVE_API_URL=/api/move

# Cloudflare Functions backend env
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_WEB_API_KEY=your-web-api-key
FIREBASE_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com
FIREBASE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Text AI backend
# Add a Workers AI binding named knightaurachess in Cloudflare Pages/Workers.
TEXT_AI_MODEL=@cf/meta/llama-3-8b-instruct

# Optional fallback if you prefer to proxy to another hosted LLM instead of Workers AI.
# TEXT_AI_UPSTREAM_URL=https://your-llm-endpoint.example/v1/chat/completions
# TEXT_AI_UPSTREAM_AUTH_BEARER=optional_api_key_or_token
